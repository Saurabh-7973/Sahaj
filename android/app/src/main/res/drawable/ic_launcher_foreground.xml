<!-- M8·02 Concept A — adaptive icon foreground. The lotus bud as line-art,
     ochre gradient on transparent. Authored in a 100-unit space and scaled
     into the inner 66% safe zone (group transform) so nothing essential
     leaves the masked circle under any launcher shape. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <group
        android:scaleX="0.6"
        android:scaleY="0.6"
        android:translateX="24"
        android:translateY="24">
        <!-- centre petal -->
        <path
            android:strokeColor="#E2AC57"
            android:strokeWidth="5"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:fillColor="#00000000"
            android:pathData="M50,24 C42,37 42,52 50,63 C58,52 58,37 50,24" />
        <!-- left petal -->
        <path
            android:strokeColor="#D79A45"
            android:strokeWidth="5"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:fillColor="#00000000"
            android:pathData="M29,41 C32,55 39,62 50,63" />
        <!-- right petal -->
        <path
            android:strokeColor="#D79A45"
            android:strokeWidth="5"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:fillColor="#00000000"
            android:pathData="M71,41 C68,55 61,62 50,63" />
        <!-- sand dot at the base -->
        <path
            android:fillColor="#D9C9A8"
            android:pathData="M50,71 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0" />
    </group>
</vector>

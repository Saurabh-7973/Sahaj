<!-- Disguise alias foreground — a plain pencil-on-card glyph in another
     developer's grey-blue aesthetic (deliberately off the Sahaj palette).
     Pairs with the "Notebook" label + the in-app cover. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- Centred in the 108 viewport and scaled to fill the safe zone (was 2.4x
         offset low-right, so the glyph read as a tiny pencil floating in a grey
         disc — which is what made the launcher/splash look broken). -->
    <group
        android:scaleX="3.2"
        android:scaleY="3.2"
        android:translateX="18"
        android:translateY="13.2">
        <!-- pencil -->
        <path
            android:strokeColor="#EAF0F5"
            android:strokeWidth="2"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:fillColor="#00000000"
            android:pathData="M4,20 L5,16 L15.5,5.5 a2.1,2.1 0 0 1 3,3 L8,19 Z" />
    </group>
</vector>
